# Dev: Vite dev server — proxy to local FastAPI (avoids CORS in browser)
VITE_PROXY_TARGET=http://127.0.0.1:8000

# Or proxy to production (same-origin /__lexie/health in browser — no LEXIE_CORS_ORIGINS change)
# VITE_PROXY_TARGET=https://lexie-server.fly.dev

# Alternative: call deployed API directly (server must set CORS for http://localhost:5173)
# VITE_LEXIE_BASE_URL=https://your-app.fly.dev

# Optional: if you add admin usage JSON with Bearer token (not used by this stub)
# VITE_LEXIE_ADMIN_TOKEN=
