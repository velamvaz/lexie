# Copy to .env and fill in. Never commit .env.
OPENAI_API_KEY=

# If unset, device key check is disabled (local dev only).
LEXIE_DEVICE_KEY=
# Required for /profile and /admin API usage in UI (non-empty). If empty, those routes return 500.
LEXIE_ADMIN_TOKEN=

# Comma-separated origins, or * for all (dev only)
LEXIE_CORS_ORIGINS=http://localhost:8000

# SQLite directory (default DB: <dir>/lexie.db)
LEXIE_DATA_DIR=./data

# Optional: full SQLAlchemy URL (overrides file under LEXIE_DATA_DIR)
# LEXIE_DATABASE_URL=sqlite:////abs/path/lexie.db

# 1 = log explain requests to DB (opt-in; includes transcript metadata)
LEXIE_LOG_REQUESTS=0

# 1 = store privacy-safe explain_telemetry rows (timings + outcomes; no transcript)
LEXIE_STORE_TELEMETRY=0

# 0 = faster path (one TTS). 1 = optional headword audio (second TTS + concat; slower).
LEXIE_HEADWORD_TTS=0

# OpenAI model overrides (optional) — must match aliases in lexie_server/config.py
# LEXIE_WHISPER_MODEL=whisper-1
# LEXIE_CHAT_MODEL=gpt-4o-mini
# LEXIE_TTS_MODEL=tts-1
# LEXIE_TTS_VOICE=nova
